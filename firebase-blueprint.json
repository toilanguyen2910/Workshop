{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's display name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "The user's role"
        }
      },
      "required": ["name", "email", "role"]
    },
    "Workshop": {
      "title": "Workshop",
      "description": "A workshop event",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the workshop"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the workshop"
        },
        "date": {
          "type": "string",
          "description": "Date of the workshop (YYYY-MM-DD)"
        },
        "time": {
          "type": "string",
          "description": "Time of the workshop (HH:MM)"
        },
        "price": {
          "type": "number",
          "description": "Price of the workshop"
        },
        "imageUrl": {
          "type": "string",
          "format": "uri",
          "description": "URL of the workshop image"
        },
        "capacity": {
          "type": "number",
          "description": "Maximum number of attendees"
        },
        "bookedCount": {
          "type": "number",
          "description": "Current number of booked attendees"
        },
        "location": {
          "type": "string",
          "description": "Location of the workshop"
        }
      },
      "required": ["title", "description", "date", "time", "price", "imageUrl", "capacity", "bookedCount", "location"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A user's booking for a workshop",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who booked"
        },
        "workshopId": {
          "type": "string",
          "description": "The ID of the booked workshop"
        },
        "status": {
          "type": "string",
          "enum": ["confirmed", "cancelled"],
          "description": "Status of the booking"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the booking was created"
        }
      },
      "required": ["userId", "workshopId", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles"
    },
    "/workshops/{workshopId}": {
      "schema": {
        "$ref": "#/entities/Workshop"
      },
      "description": "Stores workshop events"
    },
    "/bookings/{bookingId}": {
      "schema": {
        "$ref": "#/entities/Booking"
      },
      "description": "Stores workshop bookings"
    }
  }
}
